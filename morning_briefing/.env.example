# 晨间简报Agent - 环境变量配置
# 复制此文件为 .env 并填入你的API密钥

# ==================== API密钥 ====================

# CoinGecko API (可选，免费版有限制)
# 获取: https://www.coingecko.com/en/api
COINGECKO_API_KEY=your_coingecko_api_key_here

# Birdeye API (可选)
# 获取: https://birdeye.so/api
BIRDEYE_API_KEY=your_birdeye_api_key_here

# GMGN API (推荐)
# 获取: https://gmgn.ai
GMGN_API_KEY=your_gmgn_api_key_here

# Claude API (用于分析)
# 获取: https://console.anthropic.com
CLAUDE_API_KEY=your_claude_api_key_here

# ==================== 通知配置 ====================

# Discord Webhook URL
# 获取: Discord服务器设置 -> 整合 -> Webhook
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Telegram Bot配置 (可选)
# 获取: @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== OpenClaw配置 ====================

# OpenClaw Webhook URL (接收策略信号)
OPENCLAW_WEBHOOK_URL=your_openclaw_webhook_url_here

# ==================== 其他配置 ====================

# 时区
TIMEZONE=Asia/Shanghai

# 简报时间 (小时)
BRIEFING_HOUR=7
BRIEFING_MINUTE=0

# 调试模式
DEBUG=false
